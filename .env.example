# Variables de Entorno - Ejemplos
# Copiar este archivo a .env y llenar con los valores reales

# Base de Datos
DATABASE_URL=sqlite:///./agenda.db

# JWT para Autenticación
JWT_SECRET=reemplazar_con_un_secreto_largo_y_seguro_en_produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# VAPID Keys para Push Notifications (WebPush)
# Se pueden generar corriendo: `npx web-push generate-vapid-keys`
VAPID_PRIVATE_KEY=reemplazar_con_tu_vapid_private_key
VAPID_PUBLIC_KEY=reemplazar_con_tu_vapid_public_key
VAPID_CLAIM_EMAIL=mailto:admin@agendazonal.com
